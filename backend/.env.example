# ===== Backend ortam değişkenleri (örnek) =====
# Gerçek değerleri .env dosyasına yaz (o dosya GitHub'a gitmez).
# Railway'de bunları servis "Variables" bölümüne ekle.

# --- Veritabanı (Railway PostgreSQL otomatik verir) ---
DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani?schema=public"

# --- Redis (Railway Redis otomatik REDIS_URL verir) ---
REDIS_URL="redis://default:sifre@host:6379"
# (Lokal için alternatif)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"

# --- JWT (GÜÇLÜ ve rastgele olmalı, en az 32 karakter) ---
JWT_SECRET="buraya-uzun-rastgele-bir-anahtar-yaz-2024"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="buraya-baska-uzun-rastgele-anahtar"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Sunucu ---
PORT="3000"                       # Railway bunu otomatik atar

# --- CORS: virgülle birden çok origin ---
# Üretim örneği: site + lokal admin panel
CORS_ORIGINS="https://<frontend>.up.railway.app,http://localhost:3002"

# --- Yüklenen dosya (görsel/MP3) linkleri için backend'in genel adresi ---
PUBLIC_BACKEND_URL="https://<backend>.up.railway.app"

# --- Admin paneli şifresiz mod: SADECE LOKAL. Üretimde false/sil! ---
ADMIN_OPEN="false"

# --- Mail (Resend — https://resend.com) ---
# API key: Resend hesabında "API Keys" bölümünden oluştur (re_ ile başlar).
# Tanımlı değilse e-postalar gerçekten gönderilmez, sadece konsola yazılır (lokal geliştirme için güvenli varsayılan).
RESEND_API_KEY=""
# Gönderen adres. Kendi domainini Resend'de doğrulamadıysan test adresini kullan
# (bu durumda sadece Resend hesabına kayıtlı kendi e-postana gönderim yapılabilir):
MAIL_FROM="Davetim <onboarding@resend.dev>"

# --- WhatsApp destek butonu ---
# Numara SADECE burada tutulur; frontend koduna/bundle'a hiç yazılmaz.
# Uluslararası format, başında + veya 0 olmadan (Türkiye örneği): 905XXXXXXXXX
WHATSAPP_NUMBER="905070032484"
WHATSAPP_MESSAGE="Merhaba, Davetim hakkında yardım almak istiyorum."
