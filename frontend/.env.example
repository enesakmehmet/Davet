# ===== Frontend ortam değişkeni (örnek) =====
# Geliştirmede boş bırak — '/api' Vite proxy ile localhost:3000'e gider.
# Üretimde (Railway) backend'in genel adresini ver:
#   VITE_API_URL=https://<backend>.up.railway.app/api
# Alan adı aldığında:
#   VITE_API_URL=https://api.davetim.com/api
VITE_API_URL=

# ===== Analitik (opsiyonel) =====
# Boş bırakılırsa hiçbir şey yüklenmez. Doldurmak istersen:
#   VITE_GA_MEASUREMENT_ID=G-XXXXXXX      (Google Analytics 4 ölçüm kimliği)
#   VITE_META_PIXEL_ID=XXXXXXXXXXXXXXX    (Meta/Facebook Pixel kimliği)
VITE_GA_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
